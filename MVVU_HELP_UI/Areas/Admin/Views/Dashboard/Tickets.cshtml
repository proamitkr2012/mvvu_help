                                                        <a class="text-danger" role="button" aria-disabled="false">+ Add Documents</a>

                                                    </label>
                                                    <input type="file" name="file[]" accept=".pdf,.jpeg,.png" id="attachment" style="visibility: hidden; position: absolute;" multiple />
                                                    <p id="files-area">
                                                        <span id="filesList">
                                                            <span id="files-names"></span>
                                                        </span>
                                                    </p>
                                                </div>


                                                <div class="text-center mt-4">
                                                    <button class="btn btn-primary" type="submit">Save</button>
                                                    @if (Model.HelpDesk.Status == "Pending")
                                                    {
                                                        <a class="btn btn-warning" href="/admin/Dashboard/NewTickectList/@Model.HelpDesk.CTypeID">Back</a>
                                                    }
                                                    @if (Model.HelpDesk.Status == "Open")
                                                    {
                                                        <a class="btn btn-warning" href="/admin/Dashboard/OpenTickectList/@Model.HelpDesk.CTypeID">Back</a>
                                                    }
                                                    @if (Model.HelpDesk.Status == "OnHold")
                                                    {
                                                        <a class="btn btn-warning" href="/admin/Dashboard/HoldTickectList/@Model.HelpDesk.CTypeID">Back</a>
                                                    }
                                                    @if (Model.HelpDesk.Status == "Closed")
                                                    {
                                                        <a class="btn btn-warning" href="/admin/Dashboard/ClosedTickectList/@Model.HelpDesk.CTypeID">Back</a>
                                                    }
                                                    @if (Model.HelpDesk.Status == "Spam")
                                                    {
                                                        <a class="btn btn-warning" href="/admin/Dashboard/SpamTickectList/@Model.HelpDesk.CTypeID">Back</a>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>



                        </div>
                        <br />
                        <div class="card @s">
                            <div class="card-body">
                                <div class="col-12 col-sm-12">
                                    <h3 class="text-danger">
                                        <i class="fa fa-arrow-right"></i>   Transfer to Another Category
                                    </h3>
                                    <div class="form-group row m-2">
                                        <label class="col-sm-4">Choose Category to Transfer</label>
                                        <div class="col-sm-6">
                                            <select id="ForwardCTypeID" name="ForwardCTypeID" class="form-select form-control">
                                                <option selected value="">-- Select Category --</option>
                                                @foreach (var item in Model.ComplaintTypeList)
                                                {
                                                    if (Model.HelpDesk.CTypeID == item.CTypeID)
                                                    {
                                                        <option selected value="@item.CTypeID">@item.Details</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@item.CTypeID">@item.Details</option>
                                                    }
                                                }

                                            </select>
                                        </div>
                                    </div>
                                    <div class="form-group row m-2">
                                        <label class="col-sm-4">Remarks</label>
                                        <div class="col-sm-6">
                                            <input id="FRemarks" type="text" name="FRemarks" placeholder="This Issue is related to  @Model.ComplaintTypeList.Where(x=>x.CTypeID==Model.HelpDesk.CTypeID).Select(x=>x.TypeName).FirstOrDefault() Department " class="form-control">
                                        </div>
                                    </div>
                                    <div class="text-center mt-4">
                                        <button class="btn btn-danger" onclick="TransferTickets()" type="button"><i class="fa fa-arrow-right"></i> Transfer</button>

                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    const dt = new DataTransfer();

    $("#attachment").on('change', function (e) {
        for (var i = 0; i < this.files.length; i++) {
            let fileBloc = $('<span/>', { class: 'file-block' }),
                fileName = $('<span/>', { class: 'name', text: this.files.item(i).name });
            fileBloc.append('<span class="file-delete"><span>+</span></span>')
                .append(fileName);
            ///////////////////////////

            var img = this.files.item(i).name;
            var img_file_size = this.files.item(i).size;
           const file = Math.round((img_file_size / 1024));
                    // The size of the file.
             if (file < 5120) {
                var img_ext = img.split('.').pop().toLowerCase();
                if ($.inArray(img_ext, ['jpg', 'jpeg', 'pdf', 'png']) === -1) {

                    alert("File (" + img + ") type not allowed.");
                }
                else {
                    $("#filesList > #files-names").append(fileBloc);
                }
            }
            else {

                alert("File(" + img + ") size is too big.(Max 5MB)");
            }

            /////////////////////////////
        };

        for (let file of this.files) {
            dt.items.add(file);
        }

        this.files = dt.files;


        $('span.file-delete').click(function () {
            let name = $(this).next('span.name').text();
            // Supprimer l'affichage du nom de fichier
            $(this).parent().remove();
            for (let i = 0; i < dt.items.length; i++) {

                if (name === dt.items[i].getAsFile().name) {

                    dt.items.remove(i);
                    continue;
                }
            }

            document.getElementById('attachment').files = dt.files;
        });
    });
</script>
