                                                                                        <i class="fa fa-arrow-circle-right"></i> @item.TypeName
                                                                                    </div>
                                                                                    <div class="ml-auto">
                                                                                        @item.CreatedDateDisplay
                                                                                        @{
                                                                                            var n = string.IsNullOrEmpty(item.UpdatedbyName) ? "(User)" : "(" + item.UpdatedbyName + ")";
                                                                                        }
                                                                                        @n
                                                                                    </div>
                                                                                </div>
                                                                                <hr>
                                                                                @Html.Raw(item.Remarks)

                                                                                <hr style="clear:both">
