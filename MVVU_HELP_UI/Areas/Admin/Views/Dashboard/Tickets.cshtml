@model MVVU_Model.DTO.HelpDesk.TblHelpDeskDTO_AM
@{
    ViewData["Title"] = "New";
}
<link rel="stylesheet" type="text/css" href="~/trix/trix.css">
<script type="text/javascript" src="~/trix/trix.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
<style>
    .fontgap {
        letter-spacing: 1px;
    }

    .btn-lg {
        font-size: 1rem;
    }

    @@media (max-width: 990px) {

        .fontgap .btn {
            text-overflow: ellipsis;
            white-space: nowrap;
            overflow: hidden;
        }
    }

    input[type=radio] {
        border: 0px;
        width: 1rem;
        height: 1rem;
    }

    .bg {
        /* The image used */
        background-image: url("/dbru.jpeg");
        /* Full height */
        width: 100%;
        /* Center and scale the image nicely */
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
    }

    canvas {
        height: 50px !important;
    }

    .form-group {
        margin-bottom: 2px;
    }

    trix-editor {
        background-color: white;
    }

    .trix-button-group--history-tools,
    .trix-button--icon-undo,
    .trix-button--icon-redo {
        display: none;
        border: none;
    }

    .trix-button-group.trix-button-group--file-tools {
        display: none;
        border: none;
    }


    div.scroll {
        padding: 20px;
        background: linear-gradient(109.6deg, rgb(36, 45, 57) 11.2%, rgb(16, 37, 60) 51.2%, rgb(0, 0, 0) 98.6%);
        /* background-color: #000; */
        height: 600px;
        overflow-x: hidden;
        overflow-y: auto;
        /* background-image: url("/bakwhatapp.png"); */
        /* white-space: nowrap; */
    }

    .chatL {
        /* background-color: #d4edda; */
        background-image: linear-gradient(120deg, #fdfbfb 0%, #ebedee 100%);
        margin-bottom: 5px;
        border-radius: 30px;
    }

    .chatR {
        border-radius: 30px;
        /*      background-color: #f8d7da; */
        background-image: linear-gradient(60deg, #abecd6 0%, #fbed96 100%);
        margin-bottom: 5px;
    }

    .chatc {
        border-radius: 5px;
        /*     background-color: #d4edda; */
        margin-bottom: 5px;
        background-image: linear-gradient(to top, #feada6 0%, #f5efef 100%);
    }
</style>
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                @* <div class="col-sm-6">
                <h1 class="card-title">Choose Collage </h1>
                </div>*@<!-- /.col -->

            </div><!-- /.row -->
        </div><!-- /.container-fluid -->
    </div>

    <div class="content-body">
        <!-- row -->
        <div class="container-fluid">

            <div class="row">

                <div class="col-xl-12">

                    @*//////////////////////*@
                    @if (Model.HelpDesk != null)
                    {
                        <div class="card">
                            <div class="card-header " style="background-color:@Model.FlagTypeList.Where(x=>x.FID==Model.HelpDesk.FlagTypeID).Select(x=>x.Color).FirstOrDefault()">
                                <h1 class="card-title ">
                                    <i class="fa fa-flag" aria-hidden="true"></i> Ticket:- <b>#@Model.HelpDesk.TicketID</b> / HelpDeskID- @Model.HelpDesk.HelpID

                                </h1>
                                <span style="float:right">Status:- <b>@Model.HelpDesk.Status</b></span>
                            </div>
                            <!-- /.card-header -->
                            <div class="card-body">
                                @{
                                    var s = "";
                                }
                                <div class="col-xs-12 col-sm-12 col-md-12 p-0">
                                    <div class="inbox-avatar p-20 border-btm">

                                        <div class="inbox-avatar-text">

                                            <h5>
                                                <strong>Subject: </strong><span class="text-danger">@Model.HelpDesk.Subject</span>
                                                <div style="float:right">
                                                    <a href="@Model.HelpDesk.ProfilePic">
                                                        <img src="@Model.HelpDesk.ProfilePic" height="50" width="50" />
                                                    </a>
                                                </div>
                                            </h5>
                                            <div tyle="float:right">
                                                <strong>
                                                    Posted on:
                                                </strong>
                                                @Model.HelpDesk.CreatedDate.Value.ToString("dd-MMM-yyyy HH:mm:ss tt")
                                            </div>
                                            <div class="avatar-name">
                                                <strong>From: </strong>
                                                @if (Model.HelpDesk.CTypeID != 1)
                                                {
                                                    <span>
                                                        Name:- @Model.HelpDesk.Name  <span>| Email:- @Model.HelpDesk.Email</span><span>| Enroll/Roll:- @Model.HelpDesk.Enroll_Roll</span>
                                                        @if (CurrentUser.Roles.Contains("Admin") || CurrentUser.Roles.Contains("SuperAdmin"))
                                                        {
                                                            <span>| Mobile:- @Model.HelpDesk.Mobile</span>
                                                        }
                                                        <span style="float:right">Category:- <b>@Model.ComplaintTypeList.Where(x => x.CTypeID == Model.HelpDesk.CTypeID).Select(x => x.TypeName).FirstOrDefault()</b></span>
                                                    </span>
                                                }
                                                else if (Model.HelpDesk.CTypeID == 14)
                                                {
                                                    <span>
                                                        TN-No :- @Model.HelpDesk.Enroll_Roll

                                                        <span style="float:right">Category:- <b>@Model.ComplaintTypeList.Where(x => x.CTypeID == Model.HelpDesk.CTypeID).Select(x => x.TypeName).FirstOrDefault()</b></span>
                                                    </span>

                                                }
                                                else
                                                {
                                                    <span>
                                                        IGRS NO. :- @Model.HelpDesk.Enroll_Roll
                                                       
                                                       
                                                        <span style="float:right">Category:- <b>@Model.ComplaintTypeList.Where(x => x.CTypeID == Model.HelpDesk.CTypeID).Select(x => x.TypeName).FirstOrDefault()</b></span>
                                                    </span>

                                                }
                                            </div>

                                        </div>

                                    </div>

                                    <div class=" p-20 ">
                                        <div class="scroll m-3">
                                            @if (!CurrentUser.Roles.Contains("Admin") && !CurrentUser.Roles.Contains("SuperAdmin"))
                                            {

                                                if (CurrentUser.CtypeList.Contains(Model.HelpDesk.CTypeID.ToString()) == true || Model.HelpDesk.ForwardCTypeID == 0)
                                                {
                                                    ShowChat();
                                                }
                                                else
                                                {
                                                    if (CurrentUser.CtypeList.Contains(Model.HelpDesk.CTypeID.ToString()) == true && CurrentUser.CtypeList.Contains(Model.HelpDesk.ForwardCTypeID.ToString()) == true)
                                                    {

                                                        ShowChat();
                                                    }
                                                    else
                                                    {
                                                        s = "d-none";

                                                        <div class="col-12 col-sm-12">
                                                            <div class="p-3">
                                                                <div class="p-5" style="color:red;text-align:center ;font-size:30px;background-color:yellow">
                                                                    <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>This case is of a <b>restricted category</b>.<br />
                                                                    You can not view this communication details.
                                                                    <br /> <br />

                                                                    Only concerned officer is authorized to view this communication.
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                }

                                            }
                                            else
                                            {
                                                ShowChat();

                                            }


                                            @{
                                                void ShowChat()
                                                {
                                                    foreach (var item in Model.HelpDeskRemarks)
                                                    {
                                                        <div class="container">
                                                            <div class="row">
                                                                @if (string.IsNullOrEmpty(item.UpdatedbyName))
                                                                {
                                                                    <div class="col-10 col-sm-10">
                                                                        <div class="p-3 ">
                                                                            <div class=" p-4 chatL">
                                                                                <div class="d-flex">
