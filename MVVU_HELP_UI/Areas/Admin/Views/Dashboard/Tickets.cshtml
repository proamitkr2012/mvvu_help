<script>
    $('input[name=FlagTypeID]').change(function () {
        var value = $('input[name=FlagTypeID]:checked').val();
    @* alert(@Model.HelpDesk.EntryID) *@
                                                                if ('@Model.HelpDesk.EntryID' > 0) {
            var obj = {
                FlagTypeID: value,
                TicketID: '@Model.HelpDesk.TicketID'
            };

            $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("FlagStatus", "Dashboard", new { Area = "admin" })',
                data: JSON.stringify(obj),
                dataType: "json",

                success: function (response) {
    @* alert(response.data) *@
                                                                                if (response.data == "success") {
                        Swal.fire({
                            position: "top",
                            icon: "success",
                            title: "Flag has been changed",
                            showConfirmButton: false,
                            timer: 1500
                        });
                    }
                    else {
                        alert("Error! Try Again Later ")
                    }

    @*  location.reload(); *@

                                                                            },
                error: function (error) {

                }
            });
        }
    });


    function TransferTickets() {
        flag = true;
        if ($.trim($("#ForwardCTypeID").val()) == "") {
            $("#ForwardCTypeID").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#ForwardCTypeID").removeClass("input-validation-error");
        }
        if ($.trim($("#FRemarks").val()) == "") {
            $("#FRemarks").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#FRemarks").removeClass("input-validation-error");
        }

        if (flag) {
            var obj = {
                TicketID: $("#Ticket").val(),
                Remarks: $("#FRemarks").val(),
                ForwardCTypeID: $("#ForwardCTypeID").val(),
            };

            $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("TransferTicket", "Dashboard", new { area = "Admin" })',
                data: JSON.stringify(obj),
                dataType: "json",
                beforeSend: function () {
                    // setting a timeout
                    $('#btnserwait').show();
                    $('#btnser').hide();

                },
                success: function (resp) {
                    $('#Ticket').val("");
                    // alert(resp.data)
                    if (resp.data == "success") {

                        location.reload(true);

                    }
                    else {
                        Swal.fire(resp.data)

                    }
                },
                error: function (result) {
                    alert('Service call failed: ' + result.status + ' Type :' + result.statusText);
                },
                complete: function () {
                    setTimeout(function () {
                        $('#btnserwait').hide();
                        $('#btnser').show();

                    }, 0);
                },
            });

        };
    }

