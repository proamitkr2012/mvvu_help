                                                            }
                                                            <label for="FlagTypeID" style="color:@f.Color"> @f.FlagType</label>
                                                        }
                                                    </div>
                                                </fieldset>
                                            </div>
                                            @using (Html.BeginForm("Tickets", "Dashboard", FormMethod.Post, new { enctype = "multipart/form-data", id = "help" }))
                                            {
                                                <input type="hidden" id="Ticket" name="Ticket" value="@Model.HelpDesk.TicketID" />
                                                <label class="control-label" for="Message">Reply</label>
                                                @*  <textarea placeholder="Message" required="" value="" name="Message" id="Message" class="form-control"></textarea> *@
                                                <input id="Message" type="hidden" name="Message" required="" class="input-field">
                                                <trix-editor input="Message" placeholder=""></trix-editor>


                                                <div class="container">
                                                    <div class="row">
                                                        <div class="col-6 col-sm-6">
                                                            <div class="form-group row m-2">
                                                                <label class="col-sm-4">Ticket Status</label>
                                                                <div class="col-sm-6">
                                                                    <select id="Status" name="Status" class="form-select form-control">
                                                                        <option selected value="Open">Under Process</option>
                                                                        <option value="Closed">Closed</option>
                                                                        <option value="Spam">Spam</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>



                                                <div class="form-group">
