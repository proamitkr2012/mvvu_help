<script type="text/javascript">

    document.getElementById("LogPassword").addEventListener("keydown", function (e) {
        if (!e) { var e = window.event; }
       // e.preventDefault(); // sometimes useful

        // Enter is pressed
        if (e.keyCode == 13) { SubmitForm(); }
    }, false);
    // document.getElementById("OTP").addEventListener("keydown", function (e) {
    //     if (!e) { var e = window.event; }
    //    // e.preventDefault(); // sometimes useful

    //     // Enter is pressed
    //     if (e.keyCode == 13) { SubmitForm(); }
    // }, false);

    function validEmail(email) {
        const re = /^(([^<>()[\]\\.,;:\s@@"]+(\.[^<>()[\]\\.,;:\s@@"]+)*)|(".+"))@@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
        return re.test(String(email).toLowerCase());
    }
    function validPass(pass) {
        var re = /^(?=.*\d)(?=.*[!@@#$%^&*])(?=.*[a-z])(?=.*[A-Z]).{6,}$/;
    return re.test(pass);
    }


    $('#btnwaitl').hide();
    $('#btndownl').show();
    $('#btnwaitr').hide();
    $('#btndownr').show();
    $('#emailerror').html("");
    $('#moberror').html("");
    function SubmitLoginForm() {
        flag = true;
        if ($.trim($("#LogName").val()) == "") {
            $("#LogName").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#LogName").removeClass("input-validation-error");
        } if ($.trim($("#LogPassword").val()) == "") {
            $("#LogPassword").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#LogPassword").removeClass("input-validation-error");
        }


        if (flag) {
            var obj = {

                Email: $("#LogName").val(),
                Password: $("#LogPassword").val(),

            };
          //alert(obj.Email)
           $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("Login", "Account",new{area = "Admin"})',
                data: JSON.stringify(obj),
                dataType: "json",
                beforeSend: function () {
                    // setting a timeout
                    $('#btnwaitl').show();
                    $('#btndownl').hide();
                    $("#PAS_error").html("");
                },
                success: function (response) {
                   // alert(response)
                    if (response == "success") {
                        window.location.href ="@Url.Action("Index", "Dashboard",new{Area="Admin"})";
                        //$("#alertModel").modal('show');
                        //$('.modal-body > p > span').html('');
                        //$('.modal-body > p > span').html('Thanks for sharing your details with us. We will get back to you soon!');
                        $("#LogName").val("");
                        $("#LogPassword").val("");


                    }
                    else {

                        $("#PAS_error").html(response);
                        $('#btnwaitl').hide();
                        $('#btndownl').show();
                    }
                },
                error: function (result) {
                    alert('Service call failed: ' + result.status + ' Type :' + result.statusText);
                },
                complete: function () {
                    setTimeout(function () {
                        $('#btnwaitl').hide();
                        $('#btndownl').show();
                        //$(".verify").show();
                        //$(".waitverify").hide();
                    }, 0);
                },
            });
        }
    }

    function SubmitRegisterForm() {
        flag = true;
        if ($.trim($("#ResName").val()) == "") {
            $("#ResName").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#ResName").removeClass("input-validation-error");
        }


        if ($.trim($("#ResEmail").val()) == "") {
            $("#ResEmail").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#ResEmail").removeClass("input-validation-error");
        }

        if ($.trim($("#ResEmail").val()) != "") {
            var email = $.trim($("#ResEmail").val());
            if (!validEmail(email)) {
                $("#ResEmail").addClass("input-validation-error");
                flag = false;
            }
            else {
                $("#ResEmail").removeClass("input-validation-error");
            }
        }

        if ($.trim($("#ResContactNo").val()) == "") {
            $("#ResContactNo").addClass("input-validation-error");
            flag = false;
        }
        else {
            var number = $.trim($("#ResContactNo").val());
            if (number.match(/^-?\d+\.?\d*$/) && (number.match(/\d{10}/))) {
                $("#ResContactNo").removeClass("input-validation-error");
            }
            else {
                flag = false;
                if (!$("#ResContactNo").hasClass("input-validation-error"))
                    $("#ResContactNo").addClass("input-validation-error");
            }
        }
        if ($.trim($("#ResPass").val()) == "") {
            $("#ResPass").addClass("input-validation-error"); $('#passerror').html("");
            flag = false;
        }
        else {

            $("#ResPass").removeClass("input-validation-error");
        }

        //if ($.trim($("#ResPass").val()) != "") {
        //    var pass = $.trim($("#ResPass").val());
        //    if (!validPass(pass)) {
        //        $("#ResPass").addClass("input-validation-error");
        //        $('#passerror').html('Must contain at least one number and one uppercase and lowercase letter, and at least 6 or more characters');
        //        flag = false;
        //    }
        //    else {
        //        $('#passerror').html("");
        //        $("#ResPass").removeClass("input-validation-error");
        //    }
        //}



        if (flag) {
            var obj = {
                USR_NAME: $("#ResName").val(),
                EmailId: $("#ResEmail").val(),
                Mobile: $("#ResContactNo").val(),
                USR_PAS: $("#ResPass").val(),
                Disability: Number($("#Disability").val()),
            };
            //alert(JSON.stringify(obj))
            $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("RegisterUserTeacher", "Login")',
                data: JSON.stringify(obj),
                dataType: "json",
                beforeSend: function () {
                    // setting a timeout
                    $('#btnwaitr').show();
                    $('#btndownr').hide();
                },
                success: function (data) {
                    $('#emailerror').html("");
                    $('#moberror').html("");

                    if (data == "1") {
                        $('#emailerror').html("This Email is already Exits");
                        $('#ResEmail').css("margin-bottom","0px");
                    }
                    if (data == "2") {
                        $('#moberror').html("This Mobile is already Exits");
                        $('#ResContactNo').css("margin-bottom", "0px");
                    }


                    if (data== "success") {
                        //$("#alertModel").modal('show');
                        //$('.modal-body > p > span').html('');
                        //$('.modal-body > p > span').html('Thanks for sharing your details with us. We will get back to you soon!');
                        //$("#Name").val("");
                        window.location.href ="@Url.Action("index", "home")";
                        $("#ResName").val("");
                        $("#ResEmail").val("");
                        $("#ResContactNo").val("");
                            $("#ResPass").val("");
                        $("#Disability").val("");
                        $('#Disability').css("margin-bottom", "20px");
                        $('#ResContactNo').css("margin-bottom", "20px");
                        $('#ResEmail').css("margin-bottom", "20px");


                    }
                    else {
                        //$("#alertModel").modal('show');
                        //$('.modal-body > p > span').html('');
                        //$('.modal-body > p > span').html('We have already received your message!');
                        //$("#otpcondetail").hide();
                        //$("#otpmaindetail").show();
                    }
                },
                error: function (result) {
                    alert('Service call failed: ' + result.status + ' Type :' + result.statusText);
                },
                complete: function () {
                    setTimeout(function () {
                        $('#btnwaitr').hide();
                        $('#btndownr').show();
                        //$(".verify").show();
                        //$(".waitverify").hide();
                    }, 0);
                },
            });
        }
    }
</script>

