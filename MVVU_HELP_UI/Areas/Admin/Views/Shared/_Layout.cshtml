    <script>

        $(function () {
            //Initialize Select2 Elements
            $('.select2').select2()

            //Initialize Select2 Elements
            $('.select2bs4').select2({
                theme: 'bootstrap4'
            })
        });

        function PreviewImg() {

            var fuData = document.getElementById('imgfile');
            var FileUploadPath = fuData.value;

            if (FileUploadPath == '') {
                alert("Please upload an image");

            } else {
                var Extension = FileUploadPath.substring(FileUploadPath.lastIndexOf('.') + 1).toLowerCase();

                if (Extension == "gif" || Extension == "png" || Extension == "bmp"
                    || Extension == "jpeg" || Extension == "jpg" || Extension == "PNG" || Extension == "BMP" || Extension == "JPEG" || Extension == "JPG") {

                    var reader = new FileReader();

                    reader.onload = function (e) {
                        $('#imgPreview').attr('src', e.target.result);
                    }

                    reader.readAsDataURL(fuData.files[0]);
                }

                else {
                    alert("Photo only allows file types of GIF, PNG, JPG, JPEG and BMP. ");
                }
            }
        }

        ////////////////////////////////////////////////

        $("#CourseID").change(function () {
            $("#Subvloader").show();
            var divsubject = '@WebConfigSetting.BaseURL' + "/Home/GetSubjectList?CourseID=";
            $("#divsubject").load(divsubject + $('#CourseID option:selected').val(), function () { $("#Subvloader").hide(); });
        });



        $(function () {

            $('#TeacherDOBS').datetimepicker({
                format: 'L'
            });
            $('#UnivApprovDateS').datetimepicker({
                format: 'L'
            });
            $('#UnivExtensionDateS').datetimepicker({
                format: 'L'
            });
            $('#FirstAppointmentDateS').datetimepicker({
                format: 'L'
            });
            $('#PermanentAppointmentDateS').datetimepicker({
                format: 'L'
            });
            $('#AssociateProfPromotionDateS').datetimepicker({
                format: 'L'
            });
            $('#ProfPromotionDateS').datetimepicker({
                format: 'L'
            });
            $('#JoiningDateS').datetimepicker({
                format: 'L'
            });





        });
        document.getElementById("TicketBox").addEventListener("keydown", function (e) {
            if (!e) { var e = window.event; }
            // e.preventDefault(); // sometimes useful

            // Enter is pressed
            if (e.keyCode == 13) { SearchTicketAdmin(); }
        }, false);


        function SearchTicketAdmin() {
            flag = true;

            // if ($.trim($("#Ticket").val()) == "") {
            //     $("#Ticket").addClass("input-validation-error");
            //     flag = false;
            // }
            // else {
            //     $("#Ticket").removeClass("input-validation-error");
            // }
            if (flag) {
                var obj = {
                    TicketID: $("#TicketBox").val(),
                };

                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: '@Url.Action("CheckTicket", "Home", new { area = "" })',
                    data: JSON.stringify(obj),
                    dataType: "json",
                    beforeSend: function () {
                        // setting a timeout
                        $('#btnserwait').show();
                        $('#btnser').hide();

                    },
                    success: function (resp) {
                        $('#TicketBox').val("");
                        // alert(resp.data)
                        if (resp.data == "success") {
                            //  alert("/Home/Tickets/?Ticket=" + resp.res)
                            window.location.href = "/Admin/Dashboard/Tickets/?Ticket=" + resp.res + "&&t=1";

                        }
                        else {
                            Swal.fire(resp.data)

                        }
                    },
                    error: function (result) {
                        alert('Service call failed: ' + result.status + ' Type :' + result.statusText);
                    },
                    complete: function () {
                        setTimeout(function () {
                            $('#btnserwait').hide();
                            $('#btnser').show();

                        }, 0);
                    },
                });

            };
        }
    </script>
