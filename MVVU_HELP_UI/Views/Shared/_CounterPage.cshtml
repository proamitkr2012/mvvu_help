<script>



    // Function to refresh the page with a specific URL
    function refreshPage() {
        // Replace the URL with your desired destination
        var divpdis = '@MVVU_Model.WebConfigSetting.BaseURL' + "/Admin/Dashboard/CountIndex";
        $("#pagecount").load(divpdis, function () { });
    }
    function updateCounter(seconds) {
        $('#counter').text(seconds);
    }
    var counterValue = 30;

    // Update the counter initially
    updateCounter(counterValue);
    // Initial counter value (in seconds)


</script>