                            </p>
                        </div>
                    </div>
                </div>
            </div>


        </div>
    </div>
</div>
<span id="resultsd" hidden />
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>

<script>
    function validEmail(email) {
        const re = /^(([^<>()[\]\\.,;:\s@@"]+(\.[^<>()[\]\\.,;:\s@@"]+)*)|(".+"))@@((\[[0-9]{1, 3}\.[0-9]{1, 3}\.[0-9]{1, 3}\.[0-9]{1, 3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
        return re.test(String(email).toLowerCase());
    }



</script>
<script>
    $('#btnser').show();
    $('#btnserwait').hide();

    function SearchForgetTicket() {
        flag = true;
        $('#resultsd').html("");

        if ($.trim($("#Enroll_Roll").val()) == "") {
            $("#Enroll_Roll").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#Enroll_Roll").removeClass("input-validation-error");
        }

        if ($.trim($("#Name").val()) == "" && $.trim($("#Mobile").val()) == "") {
            $("#Name").addClass("input-validation-error");
            $("#Mobile").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#Name").removeClass("input-validation-error");
            $("#Mobile").removeClass("input-validation-error");
        }

        // if ($.trim($("#Email").val()) != "") {
        //     var email = $.trim($("#Email").val());
        //     if (!validEmail(email)) {
        //         $("#Email").addClass("input-validation-error");
        //         $("#Mobile").removeClass("input-validation-error");
        //         flag = false;
        //     }
        //     else {
        //         $("#Email").removeClass("input-validation-error");
        //     }
        // }
        if ($.trim($("#Mobile").val()) != "") {
            var number = $.trim($("#Mobile").val());
            if (number.match(/^[6-9][0-9]{9}$/)) {
                $("#Mobile").removeClass("input-validation-error");
            }
            else {
                flag = false;
                if (!$("#Mobile").hasClass("input-validation-error"))
                    $("#Mobile").addClass("input-validation-error");
            }
        }
        
        if (flag) {
            var obj = {
                Mobile: $("#Mobile").val(),
                Name: $("#Name").val(),
                Enroll_Roll: $("#Enroll_Roll").val(),
            };

            $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("FindTicket", "Home", new { area = "" })',
                data: JSON.stringify(obj),
                dataType: "json",
                beforeSend: function () {
                    // setting a timeout
                    $('#btnserwait').show();
                    $('#btnser').hide();

                },
                success: function (resp) {
                    $('#Ticket').val("");
                    // alert(resp.data)
                    if (resp.data == "success") {
                        // alert(JSON.stringify(resp.res));
                        var str = '<div class="table-responsive"><table style="width: 100%;font-size: 12px ;display: block; max-height: 200px; overflow: auto;" class="table table-bordered"><tr style="font-size: 15px"><th style="width: 12%">TicketID</th><th >Subject</th><th style="width: 12%">Status</th><th style="width: 15%">CreatedDate</th></tr>';
                        $.each(resp.res, function (i) {
                            var momentTime = moment(this.CreatedDate, "YYYY-MM-DDTHH:mm:ss.SS");

                            // Format the time in 12-hour format with AM/PM
                            var formattedTime = momentTime.format("DD-MMM-YYYY hh:mm:ss A");

                            str += '<tr><td><b>' + this.TicketID + '</b></td><td>' + this.Subject + '</td><td><b>' + this.Status + '</b></td><td>' + formattedTime + '</td></tr>';
                        })
                        $('#resultsd').append(str + '</table></div>');
                        Swal.fire({
                            title: 'Ticket Records',
                            html: $("#resultsd").html(),

                            width: '800px',
                            inputAttributes: {
                                autocapitalize: 'off'
                            },
                            cancelButtonText: 'Back',
                            showCancelButton: true,
                            showConfirmButton: false,
                            allowOutsideClick: () => !Swal.isLoading()
                        }).then((result) => {
                            if (result['isConfirmed']) {
                                $('#resultsd').html("");
                            }
                        })


                    }
                    else {
                        Swal.fire(resp.data)

                    }
                },
                error: function (result) {
                    alert('Service call failed: ' + result.status + ' Type :' + result.statusText);
                },
                complete: function () {
                    setTimeout(function () {
                        $('#btnserwait').hide();
                        $('#btnser').show();

                    }, 0);
                },
            });

        };
    }

</script>