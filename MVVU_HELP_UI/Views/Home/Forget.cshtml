<div class="bg">
    <div class="container ">
        <div class="row pt-5 pb-5">
            <div class="col-sm-5">
                <div class="card" style="min-height:400px">
                    <div class="card-header  bg-warning text-white text-center newsline">
                        <strong class="" style="font-size:20px">Forget Ticket</strong>
                    </div>
                    <div class="card-body">
                        <div class="row ">
                            <div class="form-group">
                                <label class="control-label" for="Enroll_Roll">Roll No.<span class="text-danger">*</span></label>
                                <input type="text" placeholder="Roll No." required="" value="" name="Enroll_Roll" id="Enroll_Roll" class="form-control">

                            </div>
                            @* <p class="por">OR</p> *@
                            <div class="form-group">
                                <label class="control-label" for="Email">Name</label>
                                <input type="text" placeholder="Name" required="" value="" name="Name" id="Name" class="form-control">

                            </div>
                            <p class="por">OR</p>
                            <div class="form-group">
                                <label class="control-label" for="Mobile">Mobile</label>
                                <input type="text" placeholder="Mobile" maxlength="10" value="" name="Mobile" id="Mobile" class="form-control">

                            </div>

                            <div class="text-center mt-4">
                                <button type="button" class="btn btn-danger" onclick="SearchForgetTicket()" id="btnser"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
                                <button type="button" class="btn btn-danger" id="btnserwait" style="display:none"><i class="fa fa-spinner fa-spin" aria-hidden="true"></i> Searching...</button>
