<script>
    function validEmail(email) {
        const re = /^(([^<>()[\]\\.,;:\s@@"]+(\.[^<>()[\]\\.,;:\s@@"]+)*)|(".+"))@@((\[[0-9]{1, 3}\.[0-9]{1, 3}\.[0-9]{1, 3}\.[0-9]{1, 3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
        return re.test(String(email).toLowerCase());
    }
    function NewSave() {
        flag = true;
        if ($.trim($("#Subject").val()) == "") {
            $("#Subject").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#Subject").removeClass("input-validation-error");
        } if ($.trim($("#Name").val()) == "") {
            $("#Name").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#Name").removeClass("input-validation-error");
        } 
        if ($.trim($("#Email").val()) == "") {
            $("#Email").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#Email").removeClass("input-validation-error");
        }

        if ($.trim($("#Email").val()) != "") {
            var email = $.trim($("#Email").val());
            if (!validEmail(email)) {
                $("#Email").addClass("input-validation-error");
                flag = false;
            }
            else {
                $("#Email").removeClass("input-validation-error");
            }
        }
        if (flag) {
            $("#help").submit();
        }
    }


</script>
<script>
    $('#btnser').show();
    $('#btnserwait').hide();

    function SearchTicket() {
        flag = true;

        if ($.trim($("#Ticket").val()) == "") {
            $("#Ticket").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#Ticket").removeClass("input-validation-error");
        }

         if ($.trim($("#Name").val()) == "" && $.trim($("#Mobile").val()) == "") {
               $("#Name").addClass("input-validation-error");
               $("#Mobile").addClass("input-validation-error");
               flag = false;
           }
           else {
               $("#Name").removeClass("input-validation-error");
               $("#Mobile").removeClass("input-validation-error");
           }

        if ($.trim($("#Mobile").val()) != "") {
        //     $("#Mobile").addClass("input-validation-error");
        //     flag = false;
        // }
        // else {
            var number = $.trim($("#Mobile").val());
            if (number.match(/^[6-9][0-9]{9}$/)) {
                $("#Mobile").removeClass("input-validation-error");
            }
            else {
                flag = false;
                if (!$("#Mobile").hasClass("input-validation-error"))
                    $("#Mobile").addClass("input-validation-error");
            }
        }
        if (flag) {
            var obj = {
                TicketID: $("#Ticket").val(),
                Mobile: $("#Mobile").val(),
                Name: $("#Name").val(),
            };

            $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("CheckTicket", "Home", new { area = "" })',
                data: JSON.stringify(obj),
                dataType: "json",
                beforeSend: function () {
                    // setting a timeout
                    $('#btnserwait').show();
                    $('#btnser').hide();

                },
                success: function (resp) {
                    $('#Ticket').val("");
                    // alert(resp.data)
                    if (resp.data == "success") {
                      //  alert("/Home/Tickets/?Ticket=" + resp.res)
                        window.location.href = "/Home/Tickets/?Ticket=" + resp.res;

                    }
                    else {
                        Swal.fire(resp.data)

                    }
                },
                error: function (result) {
                    alert('Service call failed: ' + result.status + ' Type :' + result.statusText);
                },
                complete: function () {
                    setTimeout(function () {
                        $('#btnserwait').hide();
                        $('#btnser').show();

                    }, 0);
                },
            });

        };
    }

</script>