<script>

    $('#btnser').show();
    $('#btnserwait').hide();

    $(function () {
        ChangeForIgrs();
    });

    function SearchTicket() {
        flag = true;

        if ($.trim($("#Ticket").val()) == "") {
            $("#Ticket").addClass("input-validation-error");
            flag = false;
        }
        else {
            $("#Ticket").removeClass("input-validation-error");
        }
        if (flag) {
            var obj = {
                TicketID: $("#Ticket").val(),
            };

            $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("CheckTicket", "Home", new { area = "" })',
                data: JSON.stringify(obj),
                dataType: "json",
                beforeSend: function () {
                    // setting a timeout
                    $('#btnserwait').show();
                    $('#btnser').hide();

                },
                success: function (resp) {
                    $('#Ticket').val("");
                    // alert(resp.data)
                    if (resp.data == "success") {
                        //  alert("/Home/Tickets/?Ticket=" + resp.res)
                        window.location.href = "/Home/Tickets/?Ticket=" + resp.res;

                    }
                    else {
                        Swal.fire(resp.data)

                    }
                },
                error: function (result) {
                    alert('Service call failed: ' + result.status + ' Type :' + result.statusText);
                },
                complete: function () {
                    setTimeout(function () {
                        $('#btnserwait').hide();
                        $('#btnser').show();

                    }, 0);
                },
            });

        };
    }

    function ChangeForIgrs() {

        if ($('#CTypeID option:selected').text() == 'IGRS') {
            $('#enroligrs').html("IGRS No.");
            $('#Enroll_Roll').attr("placeholder", "IGRS No.");
            $('.igrshide').hide();
            $('.duplhide').hide();
        }

        // else if ($('#CTypeID option:selected').text() == 'TN-No') {
        //     $('#enroligrs').html("TN-No");
        //     $('#Enroll_Roll').attr("placeholder", "TN-No.");
        //     $('.igrshide').hide();
        //     $('.duplhide').hide();

        // }
        else if ($('#CTypeID option:selected').text() == 'Computerized/Duplicate Marksheet') {

            $('.duplhide').show();


        }
        else {
