        }
        // if ($.trim($("#Enroll_Roll").val()) != "") {
        //     var enroll = $.trim($("#Enroll_Roll").val());

        //     if (!validEnroll(enroll)) {
        //         alert("d")
        //         $("#Enroll_Roll").addClass("input-validation-error");
        //         flag = false;
        //     }
        //     else {
        //         $("#Enroll_Roll").removeClass("input-validation-error");
        //     }
        // }
        if ($.trim($("#CTypeID").val()) == "") {
